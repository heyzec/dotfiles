// ------------------------------ ------------------------------
// Place your key bindings in this file to override the defaults
// See https://www.whitphx.info/posts/20230217-vscode-undocumented-contexts/ for when
[
    // ###############################################################################
    // ##                                                                           ##
    // ##                        1. NEOVIM-VSCODE INTEGRATION                       ##
    // ##                                                                           ##
    // ###############################################################################

    // -----------------------Escape mapping------------------------
    // jk as escape (side-effect: jj, kk and kj also will be mapped)
    // See https://github.com/vscode-neovim/vscode-neovim#composite-escape-keys
    {
        "command": "vscode-neovim.compositeEscape1",
        "key": "j",
        "when": "neovim.mode == insert && editorTextFocus",
        "args": "j"
    },
    {
        "command": "vscode-neovim.compositeEscape2",
        "key": "k",
        "when": "neovim.mode == insert && editorTextFocus",
        "args": "k"
    },
    // --------------------Restore Ctrl+C as copy-------------------
    // This makes insert mode behave more like VSCode without neovim plugin
    {
        "key": "ctrl+c",
        "command": "editor.action.clipboardCopyAction",
        "when": "neovim.mode != visual"
    },
    // ----------------------Special shortcuts----------------------
    // Alt keyboard shortcut must be explicitly defined here
    // See https://github.com/vscode-neovim/vscode-neovim#add-keybindings
    // Mapping alt in vscode also requires additional settings:
    // - window.enableMenuBarMnemonics: false
    // - window.titleBarStyle: native (if in linux)
    {
        "command": "vscode-neovim.send",
        "key": "alt+h",
        "when": "editorTextFocus && neovim.mode != insert",
        "args": "<A-h>"
    },
    {
        "command": "vscode-neovim.send",
        "key": "alt+j",
        "when": "editorTextFocus && neovim.mode != insert",
        "args": "<A-j>"
    },
    {
        "command": "vscode-neovim.send",
        "key": "alt+k",
        "when": "editorTextFocus && neovim.mode != insert",
        "args": "<A-k>"
    },
    {
        "command": "vscode-neovim.send",
        "key": "alt+l",
        "when": "editorTextFocus && neovim.mode != insert",
        "args": "<A-l>"
    },
    // ------------------------------ ------------------------------
    // Idk
    {
        "key": "tab",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "shift+tab",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    // ---------------------Toggle file explorer--------------------
    // <leader>e toggles file explorer
    // Part [1]: If buffer is (1) closed or (2) open but unfocused, open and focus to the explorer
    // Refer to map in lua/config/keymaps.lua
    // Part [2]: Otherwise, close the panel
    {
        "key": "space e",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "listFocus && !inputFocus"
    },
    // ---------------------Toggle file explorer--------------------
    // Break habit
    {
        "key": "ctrl+s",
        "command": "-workbench.action.files.save"
    },

    {
        "key": "space",
        "command": "workbench.action.togglePanel",
        "when": "problemFocus"
    },
    // ###############################################################################
    // ##                                                                           ##
    // ##                             2. VSCODE KEYBINDS                            ##
    // ##                                                                           ##
    // ###############################################################################
    // Don't make up/down interfere with suggestions (?)
    // Consider removing
    {
        "key": "down",
        "command": "-selectNextSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },
    {
        "key": "up",
        "command": "-selectPrevSuggestion",
        "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
    },

    // Sane navigation default, else filter keeps stealing focus
    // Since filter will focus on any key press
    {
        "key": "escape",
        "command": "problems.action.focusProblemsFromFilter",
        "when": "problemsFilterFocus"
    },


    // https://github.com/vscode-neovim/vscode-neovim/issues/983#issuecomment-1812198768
    {
        "key": "ctrl+u",
        "command": "-vscode-neovim.ctrl-u",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.u && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+d",
        "command": "-vscode-neovim.ctrl-d",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.d && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+u",
        "command": "runCommands",
        "when": "editorTextFocus",
        "args": {
            "commands": [
                // commands to run in sequence
                {
                    "command": "editorScroll",
                    "args": { "to": "up", "by": "wrappedLine", "value": 32 },
                },
                {
                    "command": "cursorMove",
                    "args": { "to": "viewPortCenter" },
                },
            ]
        }
    },
    {
        "key": "ctrl+d",
        "command": "runCommands",
        "when": "editorTextFocus",
        "args": {
            "commands": [
                // commands to run in sequence
                {
                    "command": "editorScroll",
                    "args": { "to": "down", "by": "wrappedLine", "value": 32 },
                },
                {
                    "command": "cursorMove",
                    "args": { "to": "viewPortCenter" },
                },
            ]
        }
    }




